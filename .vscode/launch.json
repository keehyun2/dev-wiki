{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Quartz Serve",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/quartz/bootstrap-cli.mjs",
      "args": ["build", "--serve"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Build Quartz",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/quartz/bootstrap-cli.mjs",
      "args": ["build"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "npm: serve",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "serve"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "npm: build",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
